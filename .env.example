# Copy to `.env.local` and fill in the values. `.env.local` is gitignored.

# --- P0-04: Neon Postgres -----------------------------------------------------
# Format: postgresql://user:password@host/dbname?sslmode=require
# Create a project at https://console.neon.tech and use the pooled connection.
DATABASE_URL=

# --- P0-10: Resend transactional email ---------------------------------------
# Create at https://resend.com/api-keys
# RESEND_API_KEY=
# RESEND_FROM="LastLeg <hello@lastleg.app>"

# --- P0-11: PostHog analytics ------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
