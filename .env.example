# Copy to `.env.local` and fill in the values. `.env.local` is gitignored.

# --- P0-04: Neon Postgres -----------------------------------------------------
# Format: postgresql://user:password@host/dbname?sslmode=require
# Create a project at https://console.neon.tech and use the pooled connection.
DATABASE_URL=

# --- P0-10: Resend transactional email ---------------------------------------
# Create at https://resend.com/api-keys
# RESEND_API_KEY=
# RESEND_FROM="LastLeg <hello@lastleg.app>"

# --- P0-11: PostHog analytics ------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- P1-09: Clerk auth -------------------------------------------------------
# Get from https://dashboard.clerk.com → Application → API Keys
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# Webhooks → Endpoint signing secret (svix). Used by /api/clerk/webhook.
# CLERK_WEBHOOK_SIGNING_SECRET=

# --- P1-14: Inngest background jobs ------------------------------------------
# Get from https://app.inngest.com → Settings → Manage → Signing Keys / Event Keys
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
